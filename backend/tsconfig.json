{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": false,
    "declaration": false,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "outDir": "./build",
    "rootDir": "./src",
    "typeRoots": ["./node_modules"],
    "types": ["nakama-runtime"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "build"]
}
